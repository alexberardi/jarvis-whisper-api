# =============================================================================
# jarvis-whisper-api - Environment Template
# =============================================================================
# Copy to .env and fill in values
# Port: 7706
# Run: ./run-docker-dev.sh or ./run-dev.sh
# =============================================================================

# Service URLs are resolved automatically from jarvis-config-service

# -----------------------------------------------------------------------------
# SERVER
# -----------------------------------------------------------------------------
PORT=7706

# -----------------------------------------------------------------------------
# WHISPER MODEL
# -----------------------------------------------------------------------------
# Path to whisper.cpp GGML model
WHISPER_MODEL=~/whisper.cpp/models/ggml-base.en.bin

# Path to whisper-cli binary (auto-detected if not set)
# WHISPER_CLI=/path/to/whisper-cli

# Enable CUDA acceleration for whisper.cpp build
WHISPER_ENABLE_CUDA=false

# -----------------------------------------------------------------------------
# SPEAKER RECOGNITION (optional)
# -----------------------------------------------------------------------------
# Enable speaker identification using resemblyzer
USE_VOICE_RECOGNITION=false

# Device for the speaker-recognition encoder.
# auto = CUDA if available, else CPU. cpu = force CPU. cuda = force CUDA.
# Resemblyzer on CPU adds ~5-9s per transcription request; on CUDA <1s.
# Use Dockerfile.gpu + docker-compose.gpu.yaml to build a CUDA image.
JARVIS_VOICE_DEVICE=auto

# Voice profiles directory (WAV files, filename = speaker name)
# VOICE_PROFILES_DIR=./voice_profiles

# -----------------------------------------------------------------------------
# AUTHENTICATION (App-to-app auth)
# -----------------------------------------------------------------------------
# This service's app credentials (get from jarvis-auth admin API)
# Used to validate incoming requests from command-center and other services
JARVIS_APP_ID=jarvis-whisper
JARVIS_APP_KEY=CHANGE_ME_get_from_jarvis_auth_admin

# Cache TTL for auth validation (optional)
JARVIS_AUTH_CACHE_SUCCESS_TTL=300
JARVIS_AUTH_CACHE_FAILURE_TTL=60

# -----------------------------------------------------------------------------
# CENTRALIZED LOGGING (optional)
# -----------------------------------------------------------------------------
JARVIS_LOG_CONSOLE_LEVEL=INFO
JARVIS_LOG_REMOTE_LEVEL=DEBUG
